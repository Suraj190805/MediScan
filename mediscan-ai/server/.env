# MediScan AI Server Environment
PORT=5001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/mediscan
# For MongoDB Atlas, use:
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/mediscan

# JWT
JWT_SECRET=mediscan-dev-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=mediscan-dev-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# AI Service
AI_SERVICE_URL=http://localhost:8000
